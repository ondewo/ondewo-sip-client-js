{
  "description": "ONDEWO Session Initiation Protocol (SIP) Client library for Js",
  "scripts": {
    "test": "npm run test:auth && npm run test:examples",
    "test:auth": "c8 --check-coverage --lines 100 --branches 100 --functions 100 --include auth/offlineTokenProvider.js --exclude '**/*.spec.js' --reporter text node --test auth/offlineTokenProvider.spec.js",
    "test:examples": "c8 --check-coverage --lines 100 --branches 100 --functions 100 --include examples/sipStatusExample.js --exclude '**/*.spec.js' --reporter text node --test examples/sipStatusExample.spec.js"
  },
  "devDependencies": {
    "c8": "^11.0.0"
  }
}
