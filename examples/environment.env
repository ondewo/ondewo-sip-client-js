# ONDEWO SIP JS client -- example configuration template.
#
# This is a NON-SECRET template. Copy the placeholders below and fill in your own
# values before running the Node examples (e.g. `node examples/client.js`). Every
# example loads this file via dotenv using a path relative to the script, so the
# current working directory does not matter. Do NOT put real secrets in this file.

# --- Connection: the gRPC-web (envoy) endpoint that fronts the SIP gRPC server ---
ONDEWO_HOST=localhost
ONDEWO_PORT=8443
# true -> https, false -> http (the scheme of the gRPC-web endpoint URL).
ONDEWO_USE_SECURE_CHANNEL=true

# --- Keycloak: the D18 offline-token (ROPC) login against the PUBLIC SDK client ---
KEYCLOAK_URL=https://localhost:8443/auth
KEYCLOAK_REALM=ondewo-ccai-platform
KEYCLOAK_CLIENT_ID=ondewo-sip-cai-sdk-public
# The public SDK client sends no client secret; leave blank unless using a confidential client.
KEYCLOAK_CLIENT_SECRET=
KEYCLOAK_USER_NAME=
KEYCLOAK_PASSWORD=
# TLS certificate verification for the Keycloak token call; set false only for a self-signed local Envoy.
KEYCLOAK_VERIFY_SSL=true

# --- SIP service-specific: the SIP account to register ---
ONDEWO_SIP_ACCOUNT_NAME=sip-user-1@mydomain.com
ONDEWO_SIP_ACCOUNT_PASSWORD=
# Optional: authentication user name, when it differs from the account name.
ONDEWO_SIP_AUTH_USERNAME=
# Optional: outbound proxy address, e.g. my.outbound.proxy.com
ONDEWO_SIP_OUTBOUND_PROXY=
